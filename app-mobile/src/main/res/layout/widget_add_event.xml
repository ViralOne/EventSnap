<?xml version="1.0" encoding="utf-8"?>
<!-- EventSnap home-screen widget: a quick-add bar (opens "describe") + a mic button (opens voice). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="8dp"
    android:gravity="center_vertical">

    <LinearLayout
        android:id="@+id/widget_add_bar"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/widget_bar_bg"
        android:paddingStart="18dp"
        android:paddingEnd="18dp">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_widget_edit"
            android:contentDescription="@string/widget_add_event" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="@string/widget_add_event"
            android:textColor="#CFCFCF"
            android:textSize="16sp" />
    </LinearLayout>

    <ImageView
        android:id="@+id/widget_mic"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_marginStart="8dp"
        android:padding="14dp"
        android:background="@drawable/widget_bar_bg"
        android:src="@drawable/ic_widget_mic"
        android:contentDescription="@string/shortcut_voice_long" />

</LinearLayout>
